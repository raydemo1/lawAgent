# OpenAI-compatible LLM configuration.
# DeepSeek official OpenAI-compatible base URL:
# https://api-docs.deepseek.com/
OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com
OPENAI_COMPATIBLE_API_KEY=sk-your-deepseek-api-key
OPENAI_COMPATIBLE_MODEL=deepseek-v4-flash
OPENAI_COMPATIBLE_BETA_BASE_URL=https://api.deepseek.com/beta
OPENAI_COMPATIBLE_STRUCTURED_OUTPUT=strict_tool
# none / low / medium / high / max. Keep none unless a node needs deeper reasoning.
OPENAI_COMPATIBLE_REASONING_EFFORT=none
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=60

# Review workflow retries and optional per-node model overrides.
LAWAGENT_LLM_MAX_RETRIES=3
LAWAGENT_LLM_FACT_RETRIES=3
LAWAGENT_LLM_QUERY_RETRIES=3
LAWAGENT_LLM_EVIDENCE_CHECK_RETRIES=3
LAWAGENT_LLM_RESULT_RETRIES=3
LAWAGENT_LLM_FACT_MODEL=deepseek-v4-flash
LAWAGENT_LLM_QUERY_MODEL=deepseek-v4-flash
LAWAGENT_LLM_EVIDENCE_MODEL=deepseek-v4-flash
LAWAGENT_LLM_RESULT_MODEL=deepseek-v4-flash

# Embeddings for pgvector service retrieval.
# SiliconFlow BGE-M3 is the current service-mode default on this project.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=sk-your-embedding-api-key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=60

# Optional rerank A/B. Keep off unless eval proves a gain.
RERANK_MODE=off
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=
RERANK_TIMEOUT_SECONDS=60
RERANK_WINDOW=50
RERANK_BLEND_WEIGHT=0.4

# Elasticsearch keyword service.
ES_URL=http://localhost:9200
ES_INDEX=lawagent_chunks
ES_INDEX_NAME=lawagent_chunks
ES_API_KEY=
ES_VERIFY_CERTS=true

# PostgreSQL + pgvector service.
PG_DSN=postgresql://lawagent:lawagent@localhost:5432/lawagent
PG_TABLE=lawagent_chunks

# Frontend dev server. Vite proxies /api to the backend by default; keep this
# for explicit client-side API configuration if needed.
VITE_API_BASE_URL=http://127.0.0.1:8000
